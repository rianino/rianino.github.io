---
// Codex "moto dell'acqua" — streamlines advected through a seeded vector field,
// inked stroke by stroke, as a dim full-viewport background. Click reseeds.
// No dependencies.
---

<canvas id="cflow" aria-hidden="true"></canvas>
<div class="flow-frame" aria-hidden="true"></div>

<style>
  #cflow {
    position: fixed;
    inset: 12px; /* sit inside the framed sheet */
    width: calc(100% - 24px);
    height: calc(100% - 24px);
    z-index: -2;
    pointer-events: none;
    opacity: 0.4;
  }
  /* White only at the outer edges of the sheet; the centre stays clear so the
     flow field fills top, bottom and sides as the page scrolls. */
  .flow-frame {
    position: fixed;
    inset: 12px;
    z-index: -1;
    pointer-events: none;
    background:
      linear-gradient(to right, var(--color-bg), transparent var(--space-16)),
      linear-gradient(to left, var(--color-bg), transparent var(--space-16)),
      linear-gradient(to bottom, var(--color-bg), transparent var(--space-12)),
      linear-gradient(to top, var(--color-bg), transparent var(--space-12));
  }
</style>

<script is:inline>
  (function () {
    const c = document.getElementById('cflow');
    if (!c) return;
    const ctx = c.getContext('2d');
    let seed = 1;
    function rng(s) {
      return function () {
        s |= 0; s = (s + 0x6d2b79f5) | 0;
        let t = Math.imul(s ^ (s >>> 15), 1 | s);
        t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
        return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
      };
    }
    const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
    // Resolved rgb(...) string — canvas parses it directly, and it works
    // regardless of how --color-text is aliased through var() chains.
    const inkColor = () => getComputedStyle(document.body).color || '#16161a';
    let raf;
    function draw() {
      cancelAnimationFrame(raf);
      const w = c.clientWidth || innerWidth,
        h = c.clientHeight || innerHeight,
        dpr = Math.min(devicePixelRatio, 2);
      c.width = w * dpr; c.height = h * dpr;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0); ctx.clearRect(0, 0, w, h);
      const R = rng(seed * 2654435761);
      const a1 = R() * 6, a2 = R() * 6, f1 = 1.5 + R() * 2, f2 = 1.5 + R() * 2, sw = R() * 2 * Math.PI;
      function ang(x, y) {
        const u = x / w, v = y / h;
        return Math.sin(u * f1 * 3 + a1) * 1.4 + Math.cos(v * f2 * 3 + a2) * 1.4 + Math.sin((u + v) * 4 + sw) * 0.6;
      }
      // Scale streamline count to the area so a wide viewport stays covered.
      const count = Math.min(1600, Math.round((w * h) / 360));
      const lines = [];
      for (let i = 0; i < count; i++) {
        let x = R() * w, y = R() * h; const pts = [[x, y]];
        const steps = 26 + ((R() * 30) | 0);
        for (let s = 0; s < steps; s++) {
          const a = ang(x, y); x += Math.cos(a) * 3.1; y += Math.sin(a) * 3.1;
          if (x < 0 || x > w || y < 0 || y > h) break; pts.push([x, y]);
        }
        if (pts.length > 6) lines.push({ pts, lapis: R() < 0.055 });
      }
      const ink = inkColor();
      let k = 0;
      function frame() {
        const batch = reduce ? lines.length : 30;
        for (let n = 0; n < batch && k < lines.length; n++, k++) {
          const L = lines[k];
          ctx.beginPath(); ctx.moveTo(L.pts[0][0], L.pts[0][1]);
          for (const p of L.pts) ctx.lineTo(p[0], p[1]);
          ctx.strokeStyle = L.lapis ? 'rgba(36,71,160,0.55)' : ink;
          ctx.globalAlpha = L.lapis ? 1 : 0.35;
          ctx.lineWidth = L.lapis ? 0.8 : 0.5;
          ctx.stroke();
        }
        ctx.globalAlpha = 1;
        if (k < lines.length) raf = requestAnimationFrame(frame);
      }
      frame();
    }
    // Click anywhere reseeds (canvas ignores pointer events, so listen on window).
    addEventListener('click', () => { seed++; draw(); });
    draw();
    let rt;
    addEventListener('resize', () => { clearTimeout(rt); rt = setTimeout(draw, 150); });
    // Redraw ink color when the theme toggles.
    new MutationObserver(() => draw()).observe(document.documentElement, {
      attributes: true, attributeFilter: ['data-theme'],
    });
  })();
</script>
