---
// Codex "moto dell'acqua" — 900 streamlines advected through a seeded vector
// field, inked stroke by stroke. Click reseeds. No dependencies.
---

<figure class="flowfig">
  <canvas id="cflow"></canvas>
  <figcaption>
    <span class="mono">Fig. — Moto dell'acqua</span>
    <span class="mono studyno" id="studyno">Study 0001</span>
  </figcaption>
</figure>

<style>
  .flowfig {
    position: relative;
    border: 1px solid var(--color-border-strong);
    padding: var(--space-3);
  }
  #cflow {
    width: 100%;
    display: block;
    cursor: crosshair;
  }
  .flowfig figcaption {
    margin-top: var(--space-2);
    display: flex;
    justify-content: space-between;
  }
  .studyno {
    color: var(--color-lapis);
  }
</style>

<script is:inline>
  (function () {
    const c = document.getElementById('cflow');
    if (!c) return;
    const ctx = c.getContext('2d');
    let seed = 1;
    const label = document.getElementById('studyno');
    function rng(s) {
      return function () {
        s |= 0; s = (s + 0x6d2b79f5) | 0;
        let t = Math.imul(s ^ (s >>> 15), 1 | s);
        t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
        return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
      };
    }
    const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
    // Resolved rgb(...) string — canvas parses it directly, and it works
    // regardless of how --color-text is aliased through var() chains.
    const inkColor = () => getComputedStyle(document.body).color || '#16161a';
    let raf;
    function draw() {
      cancelAnimationFrame(raf);
      const w = c.clientWidth || 480,
        h = Math.round(w * 0.72),
        dpr = Math.min(devicePixelRatio, 2);
      c.width = w * dpr; c.height = h * dpr; c.style.height = h + 'px';
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0); ctx.clearRect(0, 0, w, h);
      const R = rng(seed * 2654435761);
      const a1 = R() * 6, a2 = R() * 6, f1 = 1.5 + R() * 2, f2 = 1.5 + R() * 2, sw = R() * 2 * Math.PI;
      function ang(x, y) {
        const u = x / w, v = y / h;
        return Math.sin(u * f1 * 3 + a1) * 1.4 + Math.cos(v * f2 * 3 + a2) * 1.4 + Math.sin((u + v) * 4 + sw) * 0.6;
      }
      const lines = [];
      for (let i = 0; i < 900; i++) {
        let x = R() * w, y = R() * h; const pts = [[x, y]];
        const steps = 26 + ((R() * 30) | 0);
        for (let s = 0; s < steps; s++) {
          const a = ang(x, y); x += Math.cos(a) * 3.1; y += Math.sin(a) * 3.1;
          if (x < 0 || x > w || y < 0 || y > h) break; pts.push([x, y]);
        }
        if (pts.length > 6) lines.push({ pts, lapis: R() < 0.055 });
      }
      const ink = inkColor();
      label.textContent = 'Study ' + String(seed).padStart(4, '0');
      let k = 0;
      function frame() {
        const batch = reduce ? lines.length : 26;
        for (let n = 0; n < batch && k < lines.length; n++, k++) {
          const L = lines[k];
          ctx.beginPath(); ctx.moveTo(L.pts[0][0], L.pts[0][1]);
          for (const p of L.pts) ctx.lineTo(p[0], p[1]);
          ctx.strokeStyle = L.lapis ? 'rgba(36,71,160,0.75)' : ink;
          ctx.globalAlpha = L.lapis ? 1 : 0.5;
          ctx.lineWidth = L.lapis ? 0.9 : 0.6;
          ctx.stroke();
        }
        ctx.globalAlpha = 1;
        if (k < lines.length) raf = requestAnimationFrame(frame);
      }
      frame();
    }
    c.addEventListener('click', () => { seed++; draw(); });
    draw();
    addEventListener('resize', () => draw());
    // Redraw ink color when the theme toggles.
    new MutationObserver(() => draw()).observe(document.documentElement, {
      attributes: true, attributeFilter: ['data-theme'],
    });
  })();
</script>
