---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Bio from '../components/Bio.astro';
import FlowField from '../components/FlowField.astro';
import BlogPostList from '../components/BlogPostList.astro';
import { readingTime } from '../lib/readingTime';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
  .map((post) => ({
    slug: post.id.replace(/\.md$/, ''),
    title: post.data.title,
    description: post.data.description,
    publishedAt: post.data.publishedAt,
    readingTime: readingTime(post.body ?? ''),
  }));
---

<BaseLayout title="Rian Apolo">
  <FlowField />
  <div class="veil">
    <Bio />
    <hr />
    <BlogPostList posts={posts} />
  </div>
</BaseLayout>

<style>
  /* Content floats on the water study; a soft white wash keeps text legible
     and lets the edges dissolve into the flow field behind it. */
  .veil {
    position: relative;
    padding-block: var(--space-8);
    background: radial-gradient(
      120% 100% at 50% 30%,
      var(--color-bg) 55%,
      color-mix(in srgb, var(--color-bg) 70%, transparent) 78%,
      transparent 100%
    );
  }
</style>
