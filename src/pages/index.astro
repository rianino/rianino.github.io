---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Bio from '../components/Bio.astro';
import FlowField from '../components/FlowField.astro';
import BlogPostList from '../components/BlogPostList.astro';
import { readingTime } from '../lib/readingTime';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
  .map((post) => ({
    slug: post.id.replace(/\.md$/, ''),
    title: post.data.title,
    description: post.data.description,
    publishedAt: post.data.publishedAt,
    readingTime: readingTime(post.body ?? ''),
  }));
---

<BaseLayout title="Rian Apolo">
  <FlowField />
  <div class="veil">
    <Bio />
    <hr />
    <BlogPostList posts={posts} />
  </div>
</BaseLayout>

<style>
  /* The flow field fills the whole sheet; the content sits on a soft white
     card whose edges dissolve into the water, with generous breathing room
     between the text and where the wash gives way. */
  .veil {
    position: relative;
    padding-block: var(--space-16);
    padding-inline: var(--space-12);
    /* Radial wash: opaque under the text, fading to clear water at the sides
       and top/bottom so the flow reads around the content. */
    background: radial-gradient(
      130% 75% at 50% 40%,
      color-mix(in srgb, var(--color-bg) 90%, transparent) 0,
      color-mix(in srgb, var(--color-bg) 90%, transparent) 42%,
      color-mix(in srgb, var(--color-bg) 55%, transparent) 70%,
      transparent 100%
    );
  }

  @media (max-width: 600px) {
    .veil {
      padding-block: var(--space-12);
      padding-inline: var(--space-4);
    }
  }
</style>
